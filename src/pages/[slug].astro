---
import BaseLayout from '../layouts/BaseLayout.astro'
import SketchGallery from '../components/SketchGallery.astro'
import { pages, type PageDefinition } from '../pages'

export const getStaticPaths = () =>
  pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }))

type Props = {
  page: PageDefinition
}

const { page } = Astro.props as Props
---

<BaseLayout currentSlug={page.slug} title={`${page.title} | ヰ世界アトリエ`}>
  <main class="page page-project">
    <section class="page-heading">
      <h1>{page.title}</h1>
      <p>{page.description}</p>
    </section>

    <SketchGallery page={page} />
  </main>
</BaseLayout>
