---
import '../style.css'
import { pages } from '../pages'

type Props = {
  currentSlug?: string
  title: string
}

const { currentSlug, title } = Astro.props as Props
const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/')
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${basePath}anemoses.svg`} />
  </head>
  <body>
    <div id="app">
      <header class="site-header">
        <a href={basePath} class="site-brand">ヰ世界アトリエ</a>

        <nav class="site-nav">
          {
            pages.map((page) => (
              <a
                href={`${basePath}${page.slug}/`}
                class={page.slug === currentSlug ? 'is-current' : undefined}
              >
                {page.title}
              </a>
            ))
          }
        </nav>
      </header>

      <slot />
    </div>
  </body>
</html>
